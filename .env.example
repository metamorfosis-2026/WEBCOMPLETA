# WhatsApp (solo dígitos, sin + ni espacios)
# Ej: Argentina +54 9 11 ... => 54911XXXXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=54911XXXXXXXXXX

# Video vertical: puede ser MP4 directo o un embed URL (YouTube/Vimeo)
# MP4 ejemplo:
NEXT_PUBLIC_VERTICAL_VIDEO_URL=https://pub-a6844436cdf343eca77a9769bb10e73e.r2.dev/Que%20Es%20Bp.mp4

# Video de fondo (MP4)
NEXT_PUBLIC_BG_VIDEO_URL=https://pub-a6844436cdf343eca77a9769bb10e73e.r2.dev/1%20fondo.mp4

# Overlay mariposa (secuencia PNG con alpha)
# Subí frames a Cloudflare R2 públicos. Ejemplo:
# https://...r2.dev/maripoani/maripometavweb000.png
NEXT_PUBLIC_BUTTERFLY_FRAMES_BASE_URL="https://pub-a6844436cdf343eca77a9769bb10e73e.r2.dev/maripoani"
NEXT_PUBLIC_BUTTERFLY_FRAMES_PREFIX="maripometavweb"
NEXT_PUBLIC_BUTTERFLY_FRAMES_DIGITS=3
NEXT_PUBLIC_BUTTERFLY_FRAMES_START=0
NEXT_PUBLIC_BUTTERFLY_FRAMES_COUNT=60
NEXT_PUBLIC_BUTTERFLY_FPS=24
NEXT_PUBLIC_BUTTERFLY_MIN_DELAY_MS=12000
NEXT_PUBLIC_BUTTERFLY_MAX_DELAY_MS=22000
NEXT_PUBLIC_BUTTERFLY_MAX_WIDTH_PX=420

# -----------------------------
# Auth + DB (para login/dashboard)
# -----------------------------

# Prisma / Postgres
# Ej local:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/metamorfosis?schema=public"
DATABASE_URL=""

# NextAuth/Auth.js
NEXTAUTH_URL="http://localhost:3000"
# Generar uno seguro (ej: `openssl rand -base64 32`)
NEXTAUTH_SECRET=""

# Google OAuth
# Authorized redirect URI en Google Cloud:
# http://localhost:3000/api/auth/callback/google
# https://tu-dominio.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Superadmins por email (separados por coma)
# Ej: liyodesing@gmail.com,otroadmin@gmail.com
SUPERADMIN_EMAILS="liyodesing@gmail.com"

# Compatibilidad con bootstrap inicial
OWNER_EMAIL=""

# Crear/actualizar un admin por script:
# `npm run admin:create`
ADMIN_EMAIL="admin@local.test"
ADMIN_PASSWORD="cambia-esta-pass"
ADMIN_NAME="Super Admin"
