{
  "name": "metamorfosis-web",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "clean:next": "node scripts/clean-next.js",
    "clean": "npm run clean:next",
    "clean:hard": "powershell -NoProfile -Command \"Get-Process node -ErrorAction SilentlyContinue | Stop-Process -Force; Start-Sleep -Milliseconds 300; node scripts/clean-next.js\"",
    "admin:create": "node --env-file=.env scripts/create-admin.js",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^11.0.0",
    "nanoid": "^5.1.6",
    "next": "14.1.0",
    "next-auth": "^4.24.13",
    "prisma": "^6.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.2.1",
    "@types/react": "19.2.13",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "5.9.3"
  }
